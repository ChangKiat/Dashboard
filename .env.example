# Copy from your AI Agent .env
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Your Telegram user ID (ctx.from.id from the bot)
TELEGRAM_USER_ID=

# Optional: Supabase pooler fallback (same as AI Agent)
DATABASE_POOLER_REGION=

# API port (default 3001)
PORT=3001
